{
  "name": "vextron",
  "version": "0.1.0",
  "description": "AI-powered email client built with Electron and Vue.js",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "vue-tsc --noEmit -p src/renderer/tsconfig.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:renderer",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "email",
    "imap",
    "electron",
    "vue",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@primevue/themes": "^4.5.4",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electron-vite": "^5.0.0",
    "imapflow": "^1.2.13",
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  }
}
